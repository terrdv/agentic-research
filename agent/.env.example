# OpenAI (required)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Ollama (optional, local models)
OLLAMA_MODEL=llama3.2

# LangSmith (optional tracing)
LANGSMITH_API_KEY=
LANGCHAIN_PROJECT=agentic-research
LANGCHAIN_TRACING_V2=true

# Unpaywall (open-access PDF discovery for full-text fetching; requires a real email)
UNPAYWALL_EMAIL=
